app = Flask(__name__)
CORS(app)
api = Api(app)

# JWT配置
app.config['JWT_SECRET_KEY'] = os.getenv('JWT_SECRET_KEY', 'your-secret-key')
app.config['JWT_ACCESS_TOKEN_EXPIRES'] = timedelta(hours=1)
jwt = JWTManager(app)

class CATIAService:
                        # ========== 图片功能 ==========
                        def capture_image(self, file_path: str = 'catia_capture.png', fmt: str = 'png') -> str:
                            try:
                                if not self.catia or not hasattr(self.catia, 'active_window'):
                                    return 'fail: CATIA未连接或无活动窗口'
                                win = self.catia.active_window
                                if fmt.lower() not in ('png', 'jpg', 'jpeg', 'bmp'):
                                    return 'fail: 不支持的图片格式'
                                win.capture_to_file(file_path)
                                return file_path
                            except Exception as e:
                                return f'fail: {e}'
                    # ========== 图片API ==========
                    class CaptureImage(Resource):
                        @jwt_required()
                        @role_required('admin')
                        def post(self):
                            data = request.get_json()
                            file_path = data.get('file_path', 'catia_capture.png')
                            fmt = data.get('fmt', 'png')
                            service = CATIAService()
                            service.connect()
                            result = service.capture_image(file_path, fmt)
                            if result.startswith('fail:'):
                                return jsonify({'result': result})
                            # 返回图片下载链接
                            return jsonify({'result': 'ok', 'file': file_path, 'url': f'/api/image/download?file={os.path.basename(file_path)}'})

                    @app.route('/api/image/download')
                    @jwt_required()
                    @role_required('admin')
                    def download_image():
                        file = request.args.get('file')
                        if not file or not os.path.exists(file):
                            return jsonify({'result': 'fail: 文件不存在'}), 404
                        return send_file(file, as_attachment=True)

                    api.add_resource(CaptureImage, '/api/image/capture')
                    # ========== CATIA对象操作 ==========
                    def list_assembly_tree(self) -> Any:
                        try:
                            if not self.product:
                                return 'fail: no product loaded'
                            def walk(prod):
                                node = {'name': prod.name, 'children': []}
                                for i in range(1, prod.products.count + 1):
                                    child = prod.products.item(i)
                                    node['children'].append(walk(child))
                                return node
                            return walk(self.product)
                        except Exception as e:
                            return f'fail: {e}'

                    def get_part_property(self, prop: str) -> Any:
                        try:
                            if not self.part:
                                return 'fail: no part loaded'
                            return getattr(self.part, prop, 'fail: property not found')
                        except Exception as e:
                            return f'fail: {e}'

                    def set_part_property(self, prop: str, value: Any) -> str:
                        try:
                            if not self.part:
                                return 'fail: no part loaded'
                            setattr(self.part, prop, value)
                            self.part.update()
                            return 'ok'
                        except Exception as e:
                            return f'fail: {e}'

                    def set_material(self, material_name: str) -> str:
                        try:
                            if not self.part:
                                return 'fail: no part loaded'
                            # 伪代码，实际pycatia需支持材料库API
                            self.part.material = material_name
                            self.part.update()
                            return 'ok'
                        except Exception as e:
                            return f'fail: {e}'

                    def set_color(self, r: int, g: int, b: int) -> str:
                        try:
                            if not self.part:
                                return 'fail: no part loaded'
                            # 伪代码，实际pycatia需支持颜色API
                            self.part.color = (r, g, b)
                            self.part.update()
                            return 'ok'
                        except Exception as e:
                            return f'fail: {e}'
                # ========== CATIA对象操作API ==========
                class ListAssemblyTree(Resource):
                    @jwt_required()
                    @role_required('admin')
                    def get(self):
                        service = CATIAService()
                        service.connect()
                        result = service.list_assembly_tree()
                        return jsonify({'result': result})

                class GetPartProperty(Resource):
                    @jwt_required()
                    @role_required('admin')
                    def get(self):
                        prop = request.args.get('prop')
                        service = CATIAService()
                        service.connect()
                        result = service.get_part_property(prop)
                        return jsonify({'result': result})

                class SetPartProperty(Resource):
                    @jwt_required()
