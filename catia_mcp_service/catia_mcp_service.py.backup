# ========== Webhook/回调支持 ==========
import threading
import requests
import os
from flask import send_file


def trigger_webhook(url, payload):
    def _send():
        try:
            requests.post(url, json=payload, timeout=5)
        except Exception as e:
            logger.warning(f'Webhook failed: {e}')
    threading.Thread(target=_send, daemon=True).start()

# ========== 异步任务接口示例 ==========
from flask import Response
import uuid
tasks = {}

@app.route('/api/async/long_task', methods=['POST'])
@jwt_required()
def long_task():
    user = get_jwt_identity()
    task_id = str(uuid.uuid4())
    def do_work():
        import time
        time.sleep(5)
        tasks[task_id] = {'status': 'done', 'result': 'ok'}
        # 可在此触发 webhook
    tasks[task_id] = {'status': 'running'}
    threading.Thread(target=do_work, daemon=True).start()
    return jsonify({'task_id': task_id})

@app.route('/api/async/task_status/<task_id>', methods=['GET'])
@jwt_required()
def task_status(task_id):
    return jsonify(tasks.get(task_id, {'status': 'not_found'}))

# ========== Python SDK 入口雏形 ==========

# ========== Python SDK 完善 ==========
class CatiaMcpClient:
    def __init__(self, base_url, token):
        self.base_url = base_url
        self.token = token
    def _post(self, path, data):
        return requests.post(f'{self.base_url}{path}', json=data, headers={'Authorization': f'Bearer {self.token}'}).json()
    def _get(self, path, params=None):
        return requests.get(f'{self.base_url}{path}', params=params, headers={'Authorization': f'Bearer {self.token}'}).json()
    def batch_set_parameters(self, params):
        return self._post('/api/batch/set_parameters', {'parameters': params})
    def export_to_format(self, file_path, export_path, fmt):
        return self._post('/api/convert/export', {'file_path': file_path, 'export_path': export_path, 'fmt': fmt})
    def create_sketch(self, plane):
        return self._post('/api/sketch/create', {'plane': plane})
    def draw_point(self, sketch, x, y):
        return self._post('/api/sketch/point', {'sketch': sketch, 'x': x, 'y': y})
    def draw_line(self, sketch, x1, y1, x2, y2):
        return self._post('/api/sketch/line', {'sketch': sketch, 'x1': x1, 'y1': y1, 'x2': x2, 'y2': y2})
    def list_assembly_tree(self):
        return self._get('/api/assembly/tree')
    def get_part_property(self, prop):
        return self._get('/api/part/property', {'prop': prop})
    def set_part_property(self, prop, value):
        return self._post('/api/part/property/set', {'prop': prop, 'value': value})
    def set_material(self, material):
        return self._post('/api/part/material', {'material': material})
    def set_color(self, r, g, b):
        return self._post('/api/part/color', {'r': r, 'g': g, 'b': b})
    def capture_image(self, file_path='catia_capture.png', fmt='png'):
        return self._post('/api/image/capture', {'file_path': file_path, 'fmt': fmt})
    def download_image(self, file):
        return requests.get(f'{self.base_url}/api/image/download', params={'file': file}, headers={'Authorization': f'Bearer {self.token}'})
# ========== 命令行工具 ==========
import argparse
def main():
    parser = argparse.ArgumentParser(description='CATIA MCP CLI')
    parser.add_argument('--info', action='store_true', help='Show API info')
    parser.add_argument('--health', action='store_true', help='Check health')
    parser.add_argument('--metrics', action='store_true', help='Show metrics')
    args = parser.parse_args()
    import requests
    base_url = 'http://localhost:5000'
    if args.info:
        print(requests.get(f'{base_url}/api/v1/info').json())
    if args.health:
        print(requests.get(f'{base_url}/health').json())
    if args.metrics:
        print(requests.get(f'{base_url}/metrics').json())

if __name__ == '__main__':
    main()
# ========== API 版本管理 ==========
from flask import Blueprint

v1 = Blueprint('v1', __name__)
@app.route('/api/v1/info')
def api_v1_info():
    return jsonify({'version': 'v1', 'desc': 'CATIA MCP API v1'})

# ========== 健康检查接口 ==========
@app.route('/health', methods=['GET'])

def health():
    return jsonify({'status': 'ok', 'message': 'CATIA MCP service running'})

@app.route('/metrics', methods=['GET'])
def metrics():
    import psutil
    return jsonify({
        'cpu_percent': psutil.cpu_percent(),
        'memory': psutil.virtual_memory()._asdict(),
        'disk': psutil.disk_usage('/')._asdict()
    })

# ========== 详细错误码和错误信息 ==========
import gettext
_ = gettext.gettext

@app.errorhandler(Exception)
def handle_exception(e):
    code = 500
    msg = str(e)
    if hasattr(e, 'code'):
        code = e.code
    # 国际化错误信息
    return jsonify({'error': {'code': code, 'message': _(msg)}}), code

